## 2. Predictability

Can teammates infer behavior from the name, arguments, and return value alone? Similar code follows similar rules.

### 2.1 Manage unique names (same name, same behavior)

**Rule**  
Do not export a wrapper under the same name as the library (`http`). Use a service-specific name (`httpService`) and APIs that signal behavior (`getWithAuth`).

**Reasoning**  
When a wrapper is named identically to the library it wraps (e.g., both called `http`), readers assume they behave the same way. Hidden side effects — such as injecting an auth token — will be missed, leading to unexpected bugs and painful debugging sessions.

**Recommended Pattern**  
Make authentication obvious in the name, e.g. `httpService.getWithAuth(url)`.

```typescript
// ❌ Avoid — wrapper name collides with the library; hidden token injection is invisible to callers
import { http as httpLibrary } from "@some-library/http";

export const http = {
  async get(url: string) {
    const token = await fetchToken();
    return httpLibrary.get(url, {
      headers: { Authorization: `Bearer ${token}` },
    });
  },
};

// Usage hides the fact that a token is being sent
import { http } from "./http";
const user = await http.get("/user"); // looks like a plain GET

// ✅ Prefer — distinct name and method name make the behavior explicit
import { http as httpLibrary } from "@some-library/http";

export const httpService = {
  async getWithAuth(url: string) {
    const token = await fetchToken();
    return httpLibrary.get(url, {
      headers: { Authorization: `Bearer ${token}` },
    });
  },
};

// Usage communicates intent clearly
import { httpService } from "./httpService";
const user = await httpService.getWithAuth("/user"); // auth is obvious
```

---

### 2.2 Unify return types for similar functions

**Rule**  
Functions or hooks that belong to the same category (e.g., API-calling hooks, validation functions) must return the same shape. Never mix raw data returns with wrapped object returns within the same category.

**Reasoning**  
When similar functions return different types, every caller must inspect the return type before using it. This cognitive overhead multiplies across the codebase, and mismatches can silently produce always-truthy conditions or missing error states.

**Recommended Pattern**

```typescript
// ❌ Avoid — hooks in the same category return different shapes
function useUser() {
  const query = useQuery({ queryKey: ["user"], queryFn: fetchUser });
  return query; // returns full Query object
}

function useServerTime() {
  const query = useQuery({
    queryKey: ["serverTime"],
    queryFn: fetchServerTime,
  });
  return query.data; // returns only data — inconsistent!
}

// ✅ Prefer — all API hooks return the full Query object consistently
function useUser() {
  return useQuery({ queryKey: ["user"], queryFn: fetchUser });
}

function useServerTime() {
  return useQuery({ queryKey: ["serverTime"], queryFn: fetchServerTime });
}

// ❌ Avoid — validation functions return different types (boolean vs object)
function checkIsNameValid(name: string): boolean {
  return name.length > 0 && name.length < 20;
}

function checkIsAgeValid(age: number): { ok: boolean; reason?: string } {
  if (!Number.isInteger(age))
    return { ok: false, reason: "Age must be an integer." };
  if (age < 18) return { ok: false, reason: "Age must be 18 or older." };
  return { ok: true };
}

// Danger: checkIsAgeValid always returns a truthy object, even when ok is false
if (checkIsAgeValid(age)) {
  /* always runs */
}

// ✅ Prefer — all validation functions return a Discriminated Union
type ValidationResult = { ok: true } | { ok: false; reason: string };

function checkIsNameValid(name: string): ValidationResult {
  if (name.length === 0) return { ok: false, reason: "Name cannot be empty." };
  if (name.length >= 20)
    return { ok: false, reason: "Name must be under 20 characters." };
  return { ok: true };
}

function checkIsAgeValid(age: number): ValidationResult {
  if (!Number.isInteger(age))
    return { ok: false, reason: "Age must be an integer." };
  if (age < 18) return { ok: false, reason: "Age must be 18 or older." };
  if (age > 99) return { ok: false, reason: "Age must be 99 or younger." };
  return { ok: true };
}

const result = checkIsAgeValid(age);
if (!result.ok) {
  console.error(result.reason); // TypeScript narrows correctly
}
```

